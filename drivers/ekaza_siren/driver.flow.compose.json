    {
      "id": "siren_activated",
      "title": {
        "en": "Siren activated",
        "de": "Sirene aktiviert",
        "es": "Sirena activada",
        "it": "Sirena attivata"
      },
      "titleFormatted": {
        "en": "[[device]] siren was activated",
        "de": "Die Sirene von [[device]] wurde aktiviert",
        "es": "La sirena de [[device]] se activó",
        "it": "La sirena di [[device]] è stata attivata"
      },
      "hint": {
        "en": "Triggered when the siren starts playing.",
        "de": "Wird ausgelöst, wenn die Sirene zu spielen beginnt.",
        "es": "Se activa cuando la sirena empieza a sonar.",
        "it": "Si attiva quando la sirena inizia a suonare."
      },
      "tokens": [
        {
          "name": "duration",
          "type": "number",
          "title": {
            "en": "Duration (seconds)",
            "de": "Dauer (Sekunden)",
            "es": "Duración (segundos)",
            "it": "Durata (secondi)"
          },
          "example": 10
        }
      ]
    },
    {
      "id": "siren_deactivated",
      "title": {
        "en": "Siren deactivated",
        "de": "Sirene deaktiviert",
