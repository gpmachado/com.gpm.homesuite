[
  {
    "type": "group",
    "label": { "en": "Diagnostics" },
    "children": [
      {
        "id": "debug_frames",
        "type": "checkbox",
        "label": { "en": "Log Zigbee frames" },
        "hint": { "en": "Logs cluster, command, interval and whether the frame arrived during active polling." },
        "value": true
      },
      {
        "id": "debug_raw_payload",
        "type": "checkbox",
        "label": { "en": "Include raw frame payload" },
        "hint": { "en": "Include the hexadecimal ZCL frame for detailed analysis." },
        "value": true
      }
    ]
  },
  {
    "type": "group",
    "label": { "en": "Device control" },
    "children": [
      {
        "id": "relay_status",
        "type": "dropdown",
        "label": { "en": "Power-on behavior" },
        "hint": { "en": "State after power is restored." },
        "value": "lastState",
        "values": [
          { "id": "off",       "label": { "en": "Always Off" } },
          { "id": "on",        "label": { "en": "Always On"  } },
          { "id": "lastState", "label": { "en": "Last State" } }
        ]
      },
      {
        "id": "relay_status_current",
        "type": "label",
        "label": { "en": "Current (read from device)" },
        "value": "—"
      },
      {
        "id": "indicator_mode",
        "type": "dropdown",
        "label": { "en": "LED indicator" },
        "value": "status",
        "values": [
          { "id": "off",      "label": { "en": "Always off"       } },
          { "id": "status",   "label": { "en": "On when powered"  } },
          { "id": "position", "label": { "en": "Off when powered" } },
          { "id": "on",       "label": { "en": "Always on"        } }
        ]
      },
      {
        "id": "indicator_mode_current",
        "type": "label",
        "label": { "en": "Current (read from device)" },
        "value": "—"
      },
      {
        "id": "child_lock",
        "type": "checkbox",
        "label": { "en": "Child lock" },
        "value": false
      }
    ]
  },
  {
    "type": "group",
    "label": { "en": "Polling" },
    "children": [
      {
        "id": "pollInterval",
        "type": "number",
        "label": { "en": "Polling interval (s)" },
        "hint": { "en": "Active Homey polling interval. Keep this distinct from passive Zigbee reporting during diagnostics." },
        "value": 180,
        "min": 60,
        "max": 3600,
        "step": 1
      }
    ]
  },
  {
    "type": "group",
    "label": { "en": "Energy measurement" },
    "children": [
      {
        "id": "powerFactor",
        "type": "number",
        "label": { "en": "Power correction factor" },
        "value": 1,
        "min": 0.1,
        "max": 2,
        "step": 0.01
      },
      {
        "id": "energyFactor",
        "type": "number",
        "label": { "en": "Energy correction factor" },
        "value": 1,
        "min": 0.1,
        "max": 2,
        "step": 0.01
      },
      {
        "id": "calcPower",
        "type": "checkbox",
        "label": { "en": "Calculate power from V × A" },
        "value": true
      }
    ]
  }
]
